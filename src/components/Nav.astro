---
---
<nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-5 md:px-[60px] py-4 backdrop-blur-xl border-b border-border-soft transition-all duration-300" style="background: var(--color-nav-bg);">
  <!-- Logo -->
  <a href="/" class="flex items-center gap-3 no-underline group" aria-label="Kizercode home">
    <div class="w-10 h-10 flex items-center justify-center" style="filter: drop-shadow(0 0 8px rgba(0,200,255,0.5))">
      <svg width="40" height="40" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="navlg1" x1="0" y1="0" x2="44" y2="44" gradientUnits="userSpaceOnUse">
            <stop offset="0%" stop-color="#00c8ff"/>
            <stop offset="100%" stop-color="#00ff9d"/>
          </linearGradient>
        </defs>
        <rect width="44" height="44" rx="10" fill="var(--color-card)"/>
        <rect x="5" y="6" width="34" height="22" rx="4" fill="none" stroke="url(#navlg1)" stroke-width="1.8"/>
        <rect x="9" y="10" width="26" height="14" rx="2.5" fill="var(--color-bg)"/>
        <rect x="20" y="28" width="4" height="5" rx="1.2" fill="url(#navlg1)" opacity="0.5"/>
        <rect x="14" y="33" width="16" height="3" rx="1.5" fill="url(#navlg1)" opacity="0.5"/>
        <text x="11" y="21" font-family="JetBrains Mono, monospace" font-weight="800" font-size="10" fill="url(#navlg1)">{"{ K }"}</text>
      </svg>
    </div>
    <span class="text-lg font-extrabold tracking-tight text-primary">Kizer<span class="text-brand-cyan">code</span></span>
  </a>

  <!-- Desktop Links -->
  <ul class="hidden md:flex items-center gap-7 list-none">
    {[
      { href: '#services', en: 'Services', es: 'Servicios' },
      { href: '#why', en: 'Why Us', es: '¿Por qué?' },
      { href: '#process', en: 'Process', es: 'Proceso' },
      { href: '#pricing', en: 'Pricing', es: 'Precios' },
    ].map(({ href, en, es }) => (
      <li>
        <a href={href} class="text-muted text-sm font-medium hover:text-brand-cyan transition-colors duration-200 cursor-pointer">
          <span class="en">{en}</span><span class="es">{es}</span>
        </a>
      </li>
    ))}
    <li>
      <a href="#contact" class="px-5 py-2 rounded-lg text-sm font-bold text-bg bg-gradient-to-br from-brand-cyan to-brand-electric hover:opacity-90 hover:-translate-y-0.5 transition-all duration-200 cursor-pointer">
        <span class="en">Start a Project →</span><span class="es">Iniciar Proyecto →</span>
      </a>
    </li>
  </ul>

  <!-- Right controls: lang + theme + hamburger -->
  <div class="flex items-center gap-2">
    <!-- Language toggle -->
    <button
      id="lang-toggle"
      aria-label="Toggle language"
      class="hidden md:flex items-center gap-1 px-2.5 py-1.5 rounded-lg border border-border-soft text-muted text-xs font-mono font-bold hover:border-brand-cyan/30 hover:text-brand-cyan transition-all duration-200 cursor-pointer"
      style="background: var(--color-card);"
    >
      <span id="lang-label">EN</span>
    </button>

    <!-- Theme toggle -->
    <button
      id="theme-toggle"
      aria-label="Toggle dark/light mode"
      class="hidden md:flex w-9 h-9 items-center justify-center rounded-lg border border-border-soft text-muted hover:border-brand-cyan/30 hover:text-brand-cyan transition-all duration-200 cursor-pointer"
      style="background: var(--color-card);"
    >
      <!-- Sun icon (shown in dark mode) -->
      <svg id="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
        <circle cx="12" cy="12" r="5"/>
        <line x1="12" y1="1" x2="12" y2="3"/>
        <line x1="12" y1="21" x2="12" y2="23"/>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
        <line x1="1" y1="12" x2="3" y2="12"/>
        <line x1="21" y1="12" x2="23" y2="12"/>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
      <!-- Moon icon (shown in light mode) -->
      <svg id="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" class="hidden">
        <path d="M21 12.79A9 9 0 1111.21 3a7 7 0 009.79 9.79z"/>
      </svg>
    </button>

    <!-- Mobile hamburger -->
    <button id="nav-toggle" class="md:hidden flex flex-col gap-1.5 p-2 cursor-pointer bg-transparent border-0" aria-label="Toggle menu" aria-expanded="false">
      <span class="block w-5 h-0.5 bg-primary transition-all duration-300" id="bar1" style="background: var(--color-text)"></span>
      <span class="block w-5 h-0.5 bg-primary transition-all duration-300" id="bar2" style="background: var(--color-text)"></span>
      <span class="block w-5 h-0.5 bg-primary transition-all duration-300" id="bar3" style="background: var(--color-text)"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="absolute top-full left-0 right-0 hidden flex-col border-b border-border-soft py-5 px-5" style="background: var(--color-bg-2);">
    {[
      { href: '#services', en: 'Services', es: 'Servicios' },
      { href: '#why', en: 'Why Us', es: '¿Por qué Nosotros?' },
      { href: '#process', en: 'Process', es: 'Proceso' },
      { href: '#pricing', en: 'Pricing', es: 'Precios' },
    ].map(({ href, en, es }) => (
      <a href={href} class="py-3.5 text-muted hover:text-brand-cyan transition-colors duration-200 font-medium border-b border-border-soft text-sm">
        <span class="en">{en}</span><span class="es">{es}</span>
      </a>
    ))}
    <a href="#contact" class="mt-4 px-6 py-3 rounded-lg text-sm font-bold text-bg text-center bg-gradient-to-br from-brand-cyan to-brand-electric">
      <span class="en">Start a Project →</span><span class="es">Iniciar Proyecto →</span>
    </a>
    <!-- Mobile controls row -->
    <div class="flex items-center gap-3 mt-4 pt-4 border-t border-border-soft">
      <button id="lang-toggle-mobile" class="flex items-center gap-1 px-3 py-2 rounded-lg border border-border-soft text-muted text-xs font-mono font-bold hover:text-brand-cyan transition-all cursor-pointer" style="background: var(--color-card);">
        <span id="lang-label-mobile">EN</span>
      </button>
      <button id="theme-toggle-mobile" class="flex items-center gap-2 px-3 py-2 rounded-lg border border-border-soft text-muted text-xs font-semibold hover:text-brand-cyan transition-all cursor-pointer" style="background: var(--color-card);">
        <span id="theme-label-mobile">Dark Mode</span>
      </button>
    </div>
  </div>
</nav>

<script>
  // ── Mobile menu ──────────────────────────────────────────────────────
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');
  const bar1 = document.getElementById('bar1');
  const bar2 = document.getElementById('bar2');
  const bar3 = document.getElementById('bar3');
  let menuOpen = false;

  toggle?.addEventListener('click', () => {
    menuOpen = !menuOpen;
    menu?.classList.toggle('hidden', !menuOpen);
    menu?.classList.toggle('flex', menuOpen);
    toggle.setAttribute('aria-expanded', menuOpen.toString());
    if (bar1) bar1.style.transform = menuOpen ? 'rotate(45deg) translate(4px, 5px)' : '';
    if (bar2) bar2.style.opacity = menuOpen ? '0' : '1';
    if (bar3) bar3.style.transform = menuOpen ? 'rotate(-45deg) translate(4px, -5px)' : '';
  });

  menu?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      menuOpen = false;
      menu.classList.add('hidden');
      menu.classList.remove('flex');
      if (bar1) bar1.style.transform = '';
      if (bar2) bar2.style.opacity = '1';
      if (bar3) bar3.style.transform = '';
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });

  // ── Language toggle ──────────────────────────────────────────────────
  function updateLangUI(lang: string) {
    const labels = [
      document.getElementById('lang-label'),
      document.getElementById('lang-label-mobile'),
    ];
    labels.forEach(el => { if (el) el.textContent = lang.toUpperCase(); });
  }

  function toggleLang() {
    const current = document.documentElement.getAttribute('lang') || 'en';
    const next = current === 'en' ? 'es' : 'en';
    document.documentElement.setAttribute('lang', next);
    localStorage.setItem('kz-lang', next);
    updateLangUI(next);
  }

  document.getElementById('lang-toggle')?.addEventListener('click', toggleLang);
  document.getElementById('lang-toggle-mobile')?.addEventListener('click', toggleLang);

  // ── Theme toggle (View Transitions) ──────────────────────────────────
  function updateThemeUI(theme: string) {
    const isDark = theme === 'dark';
    const sunIcon = document.getElementById('icon-sun');
    const moonIcon = document.getElementById('icon-moon');
    const label = document.getElementById('theme-label-mobile');
    if (sunIcon) sunIcon.classList.toggle('hidden', !isDark);
    if (moonIcon) moonIcon.classList.toggle('hidden', isDark);
    if (label) label.textContent = isDark ? 'Light Mode' : 'Dark Mode';
  }

  async function toggleTheme() {
    const current = document.documentElement.getAttribute('data-theme') || 'dark';
    const next = current === 'dark' ? 'light' : 'dark';
    localStorage.setItem('kz-theme', next);

    if (!document.startViewTransition) {
      document.documentElement.setAttribute('data-theme', next);
      updateThemeUI(next);
      return;
    }

    const transition = document.startViewTransition(() => {
      document.documentElement.setAttribute('data-theme', next);
      updateThemeUI(next);
    });

    await transition.ready;

    document.documentElement.animate(
      { clipPath: ['inset(0 0 100% 0)', 'inset(0)'] },
      {
        pseudoElement: '::view-transition-new(root)',
        duration: 600,
        easing: 'cubic-bezier(0.22, 1, 0.36, 1)',
      },
    );
  }

  document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);
  document.getElementById('theme-toggle-mobile')?.addEventListener('click', toggleTheme);

  // ── Init UI from saved state ──────────────────────────────────────────
  const savedTheme = document.documentElement.getAttribute('data-theme') || 'dark';
  const savedLang = document.documentElement.getAttribute('lang') || 'en';
  updateThemeUI(savedTheme);
  updateLangUI(savedLang);
</script>
