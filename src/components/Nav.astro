---
---
<nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-4 md:px-[60px] py-3 backdrop-blur-xl border-b border-border-soft transition-all duration-300" style="background: var(--color-nav-bg);">
  <!-- Logo -->
  <a href="/" class="flex items-center gap-2.5 no-underline group shrink-0" aria-label="Kizercode home">
    <div class="w-9 h-9 flex items-center justify-center" style="filter: drop-shadow(0 0 8px rgba(0,200,255,0.5))">
      <svg width="36" height="36" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="navlg1" x1="0" y1="0" x2="44" y2="44" gradientUnits="userSpaceOnUse">
            <stop offset="0%" stop-color="#00c8ff"/>
            <stop offset="100%" stop-color="#00ff9d"/>
          </linearGradient>
        </defs>
        <rect width="44" height="44" rx="10" fill="var(--color-card)"/>
        <rect x="5" y="6" width="34" height="22" rx="4" fill="none" stroke="url(#navlg1)" stroke-width="1.8"/>
        <rect x="9" y="10" width="26" height="14" rx="2.5" fill="var(--color-bg)"/>
        <rect x="20" y="28" width="4" height="5" rx="1.2" fill="url(#navlg1)" opacity="0.5"/>
        <rect x="14" y="33" width="16" height="3" rx="1.5" fill="url(#navlg1)" opacity="0.5"/>
        <text x="11" y="21" font-family="JetBrains Mono, monospace" font-weight="800" font-size="10" fill="url(#navlg1)">{"{ K }"}</text>
      </svg>
    </div>
    <span class="text-base font-extrabold tracking-tight text-primary">Kizer<span class="text-brand-cyan">code</span></span>
  </a>

  <!-- Desktop Links -->
  <ul class="hidden md:flex items-center gap-7 list-none">
    {[
      { href: '#services', en: 'Services', es: 'Servicios' },
      { href: '#why', en: 'Why Us', es: '¿Por qué?' },
      { href: '#process', en: 'Process', es: 'Proceso' },
      { href: '#pricing', en: 'Pricing', es: 'Precios' },
    ].map(({ href, en, es }) => (
      <li>
        <a
          href={href}
          data-nav-link={href.replace('#','')}
          class="nav-link text-muted text-sm font-medium hover:text-brand-cyan transition-colors duration-200 cursor-pointer relative pb-0.5"
        >
          <span class="en">{en}</span><span class="es">{es}</span>
          <span class="nav-indicator absolute -bottom-1 left-0 right-0 h-[2px] rounded-full bg-brand-cyan scale-x-0 transition-transform duration-200 origin-left"></span>
        </a>
      </li>
    ))}
    <li>
      <a href="#contact" class="px-5 py-2 rounded-lg text-sm font-bold text-bg bg-gradient-to-br from-brand-cyan to-brand-electric hover:opacity-90 hover:-translate-y-0.5 transition-all duration-200 cursor-pointer">
        <span class="en">Start a Project →</span><span class="es">Iniciar Proyecto →</span>
      </a>
    </li>
  </ul>

  <!-- Right controls -->
  <div class="flex items-center gap-1.5 md:gap-2">
    <!-- Language toggle (always visible) -->
    <button
      id="lang-toggle"
      aria-label="Toggle language"
      class="flex items-center gap-1 px-2 py-1.5 rounded-lg border border-border-soft text-muted text-xs font-mono font-bold hover:border-brand-cyan/40 hover:text-brand-cyan transition-all duration-200 cursor-pointer"
      style="background: var(--color-card);"
    >
      <span id="lang-label">EN</span>
    </button>

    <!-- Theme toggle (always visible) -->
    <button
      id="theme-toggle"
      aria-label="Toggle dark/light mode"
      class="flex w-8 h-8 md:w-9 md:h-9 items-center justify-center rounded-lg border border-border-soft text-muted hover:border-brand-cyan/40 hover:text-brand-cyan transition-all duration-200 cursor-pointer"
      style="background: var(--color-card);"
    >
      <svg id="icon-sun" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
        <circle cx="12" cy="12" r="5"/>
        <line x1="12" y1="1" x2="12" y2="3"/>
        <line x1="12" y1="21" x2="12" y2="23"/>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
        <line x1="1" y1="12" x2="3" y2="12"/>
        <line x1="21" y1="12" x2="23" y2="12"/>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
      <svg id="icon-moon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" class="hidden">
        <path d="M21 12.79A9 9 0 1111.21 3a7 7 0 009.79 9.79z"/>
      </svg>
    </button>

    <!-- Mobile hamburger -->
    <button id="nav-toggle" class="md:hidden flex flex-col justify-center items-center w-8 h-8 gap-1.5 cursor-pointer bg-transparent border-0 shrink-0" aria-label="Toggle menu" aria-expanded="false">
      <span class="block w-5 h-[1.5px] transition-all duration-300 rounded-full" id="bar1" style="background: var(--color-text)"></span>
      <span class="block w-5 h-[1.5px] transition-all duration-300 rounded-full" id="bar2" style="background: var(--color-text)"></span>
      <span class="block w-3.5 h-[1.5px] transition-all duration-300 rounded-full ml-auto" id="bar3" style="background: var(--color-text)"></span>
    </button>
  </div>

  <!-- Mobile menu overlay -->
  <div
    id="mobile-menu"
    class="absolute top-full left-0 right-0 border-b border-border-soft overflow-hidden"
    style="background: var(--color-bg-2); max-height: 0; transition: max-height 0.35s cubic-bezier(0.4,0,0.2,1), opacity 0.25s ease; opacity: 0; pointer-events: none;"
  >
    <div class="px-4 pt-2 pb-5">
      <!-- Section links -->
      <div class="flex flex-col">
        {[
          { href: '#services', en: 'Services', es: 'Servicios' },
          { href: '#why', en: 'Why Us', es: '¿Por qué Nosotros?' },
          { href: '#process', en: 'Process', es: 'Proceso' },
          { href: '#pricing', en: 'Pricing', es: 'Precios' },
        ].map(({ href, en, es }) => (
          <a
            href={href}
            data-mob-link={href.replace('#','')}
            class="mob-nav-link flex items-center justify-between py-3.5 text-muted font-medium border-b border-border-soft text-sm group transition-colors duration-200"
          >
            <span>
              <span class="en">{en}</span><span class="es">{es}</span>
            </span>
            <svg class="w-4 h-4 text-brand-cyan/0 group-[.active]:text-brand-cyan transition-colors duration-200" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="3" fill="currentColor" stroke="none"/>
            </svg>
          </a>
        ))}
      </div>

      <!-- CTA -->
      <a href="#contact" class="mob-close-link mt-4 flex items-center justify-center gap-2 px-6 py-3 rounded-xl text-sm font-bold text-bg bg-gradient-to-br from-brand-cyan to-brand-electric hover:opacity-90 transition-opacity duration-200">
        <span class="en">Start a Project</span><span class="es">Iniciar Proyecto</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</nav>

<style>
  .nav-link.active .nav-indicator { transform: scaleX(1); }
  .nav-link.active { color: var(--color-text); }
  .mob-nav-link.active { color: var(--color-text); }
  #bar3 { transition: width 0.3s ease, margin 0.3s ease; }
</style>

<script>
  // ── Mobile menu ───────────────────────────────────────────────────────
  const toggle = document.getElementById('nav-toggle') as HTMLButtonElement;
  const menu = document.getElementById('mobile-menu') as HTMLElement;
  const bar1 = document.getElementById('bar1') as HTMLElement;
  const bar2 = document.getElementById('bar2') as HTMLElement;
  const bar3 = document.getElementById('bar3') as HTMLElement;
  let menuOpen = false;

  function openMenu() {
    menuOpen = true;
    menu.style.maxHeight = menu.scrollHeight + 80 + 'px';
    menu.style.opacity = '1';
    menu.style.pointerEvents = 'auto';
    toggle.setAttribute('aria-expanded', 'true');
    bar1.style.transform = 'rotate(45deg) translate(3px, 4px)';
    bar2.style.opacity = '0';
    bar2.style.transform = 'scaleX(0)';
    bar3.style.transform = 'rotate(-45deg) translate(3px, -4px)';
    bar3.style.width = '20px';
    bar3.style.marginLeft = 'auto';
    bar3.style.marginRight = 'auto';
  }

  function closeMenu() {
    menuOpen = false;
    menu.style.maxHeight = '0';
    menu.style.opacity = '0';
    menu.style.pointerEvents = 'none';
    toggle.setAttribute('aria-expanded', 'false');
    bar1.style.transform = '';
    bar2.style.opacity = '1';
    bar2.style.transform = '';
    bar3.style.transform = '';
    bar3.style.width = '14px';
    bar3.style.marginLeft = 'auto';
    bar3.style.marginRight = '0';
  }

  toggle?.addEventListener('click', () => menuOpen ? closeMenu() : openMenu());

  // close on link click
  menu?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', closeMenu);
  });

  // ── Scroll Spy ───────────────────────────────────────────────────────
  const sections = ['services', 'why', 'process', 'pricing'];
  let activeSection = '';

  function setActive(id: string) {
    if (id === activeSection) return;
    activeSection = id;

    document.querySelectorAll<HTMLElement>('[data-nav-link]').forEach(el => {
      el.classList.toggle('active', el.dataset.navLink === id);
    });
    document.querySelectorAll<HTMLElement>('[data-mob-link]').forEach(el => {
      el.classList.toggle('active', el.dataset.mobLink === id);
    });
  }

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          setActive(entry.target.id);
        }
      });
    },
    { rootMargin: '-30% 0px -60% 0px', threshold: 0 }
  );

  sections.forEach(id => {
    const el = document.getElementById(id);
    if (el) observer.observe(el);
  });

  // ── Language toggle ───────────────────────────────────────────────────
  function updateLangUI(lang: string) {
    const label = document.getElementById('lang-label');
    if (label) label.textContent = lang.toUpperCase();
  }

  function toggleLang() {
    const current = document.documentElement.getAttribute('lang') || 'en';
    const next = current === 'en' ? 'es' : 'en';
    document.documentElement.setAttribute('lang', next);
    localStorage.setItem('kz-lang', next);
    updateLangUI(next);
  }

  document.getElementById('lang-toggle')?.addEventListener('click', toggleLang);

  // ── Theme toggle ──────────────────────────────────────────────────────
  function updateThemeUI(theme: string) {
    const isDark = theme === 'dark';
    const sunIcon = document.getElementById('icon-sun');
    const moonIcon = document.getElementById('icon-moon');
    if (sunIcon) sunIcon.classList.toggle('hidden', !isDark);
    if (moonIcon) moonIcon.classList.toggle('hidden', isDark);
  }

  async function toggleTheme() {
    const current = document.documentElement.getAttribute('data-theme') || 'dark';
    const next = current === 'dark' ? 'light' : 'dark';
    localStorage.setItem('kz-theme', next);

    if (!document.startViewTransition) {
      document.documentElement.setAttribute('data-theme', next);
      updateThemeUI(next);
      return;
    }

    const transition = document.startViewTransition(() => {
      document.documentElement.setAttribute('data-theme', next);
      updateThemeUI(next);
    });

    await transition.ready;

    document.documentElement.animate(
      { clipPath: ['inset(0 0 100% 0)', 'inset(0)'] },
      {
        pseudoElement: '::view-transition-new(root)',
        duration: 600,
        easing: 'cubic-bezier(0.22, 1, 0.36, 1)',
      },
    );
  }

  document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);

  // ── Init from saved state ─────────────────────────────────────────────
  const savedTheme = document.documentElement.getAttribute('data-theme') || 'dark';
  const savedLang = document.documentElement.getAttribute('lang') || 'en';
  updateThemeUI(savedTheme);
  updateLangUI(savedLang);
</script>
