---
const currentYear = new Date().getFullYear();

const services = [
  { label_en: 'Web Applications', label_es: 'Aplicaciones Web', href: '#services' },
  { label_en: 'Mobile Apps', label_es: 'Apps Móviles', href: '#services' },
  { label_en: 'Brand Identity', label_es: 'Identidad de Marca', href: '#services' },
  { label_en: 'Digital Marketing', label_es: 'Marketing Digital', href: '#services' },
  { label_en: 'Billing Systems', label_es: 'Facturación', href: '#services' },
  { label_en: 'AI Automation', label_es: 'Automatización IA', href: '#services' },
];

const company = [
  { label_en: 'Why Us', label_es: '¿Por qué Nosotros?', href: '#why' },
  { label_en: 'Our Process', label_es: 'Nuestro Proceso', href: '#process' },
  { label_en: 'Pricing', label_es: 'Precios', href: '#pricing' },
  { label_en: 'Client Reviews', label_es: 'Reseñas', href: '#reviews' },
  { label_en: 'Contact', label_es: 'Contacto', href: '#contact' },
];
---

<footer class="bg-bg-2 border-t border-border-soft">
  <!-- Main footer content -->
  <div class="px-5 md:px-[60px] py-14 max-w-[1200px] mx-auto">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Brand column -->
      <div class="sm:col-span-2 lg:col-span-1">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-3 mb-5 no-underline group" aria-label="Kizercode home">
          <div class="w-10 h-10 flex items-center justify-center" style="filter: drop-shadow(0 0 6px rgba(0,200,255,0.4))">
            <svg width="40" height="40" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <linearGradient id="footerlg1" x1="0" y1="0" x2="44" y2="44" gradientUnits="userSpaceOnUse">
                  <stop offset="0%" stop-color="#00c8ff"/>
                  <stop offset="100%" stop-color="#00ff9d"/>
                </linearGradient>
              </defs>
              <rect width="44" height="44" rx="10" fill="var(--color-card)"/>
              <rect x="5" y="6" width="34" height="22" rx="4" fill="none" stroke="url(#footerlg1)" stroke-width="1.8"/>
              <rect x="9" y="10" width="26" height="14" rx="2.5" fill="var(--color-bg)"/>
              <rect x="20" y="28" width="4" height="5" rx="1.2" fill="url(#footerlg1)" opacity="0.5"/>
              <rect x="14" y="33" width="16" height="3" rx="1.5" fill="url(#footerlg1)" opacity="0.5"/>
              <text x="11" y="21" font-family="JetBrains Mono, monospace" font-weight="800" font-size="10" fill="url(#footerlg1)">{"{ K }"}</text>
            </svg>
          </div>
          <span class="text-lg font-extrabold tracking-tight text-primary">Kizer<span class="text-brand-cyan">code</span></span>
        </a>

        <p class="text-muted text-sm leading-relaxed mb-4 max-w-[260px]">
          <span class="en">Brand · Software · Growth. Your full-stack digital partner in Honduras.</span>
          <span class="es">Marca · Software · Crecimiento. Tu socio digital integral en Honduras.</span>
        </p>

        <!-- Social links -->
        <div class="flex gap-3 mb-4">
          <a
            href="https://www.linkedin.com/company/kizercode"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Kizercode on LinkedIn"
            class="w-9 h-9 rounded-xl flex items-center justify-center border border-border-soft text-muted hover:text-brand-cyan hover:border-brand-cyan/30 transition-all duration-200 cursor-pointer"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
              <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2zM4 6a2 2 0 100-4 2 2 0 000 4z"/>
            </svg>
          </a>
          <a
            href="https://github.com/kizercode"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Kizercode on GitHub"
            class="w-9 h-9 rounded-xl flex items-center justify-center border border-border-soft text-muted hover:text-brand-cyan hover:border-brand-cyan/30 transition-all duration-200 cursor-pointer"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
              <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22"/>
            </svg>
          </a>
          <a
            href="https://wa.me/50498622160"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Kizercode on WhatsApp"
            class="w-9 h-9 rounded-xl flex items-center justify-center border border-border-soft text-muted hover:text-brand-electric hover:border-brand-electric/30 transition-all duration-200 cursor-pointer"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </a>
        </div>

        <!-- Status badge -->
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-brand-electric/15" style="background: rgba(0,255,157,0.05);">
          <span class="w-1.5 h-1.5 rounded-full bg-brand-electric animate-pulse-dot"></span>
          <span class="text-brand-electric text-[11px] font-semibold">
            <span class="en">Open for projects</span><span class="es">Aceptando proyectos</span>
          </span>
        </div>
      </div>

      <!-- Services column -->
      <div>
        <h4 class="font-bold text-primary text-sm mb-5">
          <span class="en">Services</span><span class="es">Servicios</span>
        </h4>
        <ul class="space-y-3">
          {services.map(({ label_en, label_es, href }) => (
            <li>
              <a href={href} class="text-muted text-sm hover:text-brand-cyan transition-colors duration-200 cursor-pointer">
                <span class="en">{label_en}</span><span class="es">{label_es}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company column -->
      <div>
        <h4 class="font-bold text-primary text-sm mb-5">
          <span class="en">Company</span><span class="es">Empresa</span>
        </h4>
        <ul class="space-y-3">
          {company.map(({ label_en, label_es, href }) => (
            <li>
              <a href={href} class="text-muted text-sm hover:text-brand-cyan transition-colors duration-200 cursor-pointer">
                <span class="en">{label_en}</span><span class="es">{label_es}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact column -->
      <div>
        <h4 class="font-bold text-primary text-sm mb-5">
          <span class="en">Contact</span><span class="es">Contacto</span>
        </h4>
        <div class="space-y-4">
          <div>
            <p class="text-[11px] font-mono text-muted-2 uppercase tracking-widest mb-1">Email</p>
            <a
              href="mailto:hello@kizercode.com"
              class="text-muted text-sm hover:text-brand-cyan transition-colors duration-200 cursor-pointer"
            >
              hello@kizercode.com
            </a>
          </div>
          <div>
            <p class="text-[11px] font-mono text-muted-2 uppercase tracking-widest mb-1">WhatsApp</p>
            <a
              href="https://wa.me/50498622160"
              target="_blank"
              rel="noopener noreferrer"
              class="text-muted text-sm hover:text-brand-cyan transition-colors duration-200 cursor-pointer"
            >
              +504 9862-2160
            </a>
          </div>
          <div>
            <p class="text-[11px] font-mono text-muted-2 uppercase tracking-widest mb-1">
              <span class="en">Location</span><span class="es">Ubicación</span>
            </p>
            <p class="text-muted text-sm">El Progreso, Yoro, Honduras</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-border-soft px-5 md:px-[60px] py-5">
    <div class="max-w-[1200px] mx-auto flex flex-col md:flex-row items-center justify-between gap-3">
      <p class="font-mono text-[11px] text-muted-2">
        &copy; {currentYear} Kizercode.
        <span class="en">All rights reserved. Made with ♥ in Honduras 🇭🇳</span>
        <span class="es">Todos los derechos reservados. Hecho con ♥ en Honduras 🇭🇳</span>
      </p>
      <div class="flex gap-5">
        <a href="/privacy" class="text-muted-2 text-xs hover:text-muted transition-colors duration-200 cursor-pointer font-mono">
          <span class="en">Privacy Policy</span><span class="es">Privacidad</span>
        </a>
        <a href="/terms" class="text-muted-2 text-xs hover:text-muted transition-colors duration-200 cursor-pointer font-mono">
          <span class="en">Terms of Service</span><span class="es">Términos</span>
        </a>
      </div>
    </div>
  </div>
</footer>
