---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'Kizercode — Brand · Software · Growth | Honduras',
  description = 'Custom software, web & mobile apps, branding, digital marketing and billing systems for enterprises in Honduras and Latin America.',
  image = '/og-image.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="en" data-theme="dark" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="view-transition" content="same-origin" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content="software development Honduras, web apps, mobile apps, branding, marketing digital, billing systems, digital transformation, enterprise software, El Progreso Yoro" />
  <meta name="author" content="Kizercode" />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, Astro.site)} />
  <meta property="og:locale" content="en_US" />
  <meta property="og:site_name" content="Kizercode" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(image, Astro.site)} />

  <!-- Fonts — non-render-blocking: preload + swap -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="preload"
    as="style"
    href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap"
  />
  <link
    href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap"
    rel="stylesheet"
    media="print"
    onload="this.media='all'"
  />
  <noscript>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
  </noscript>

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Schema.org -->
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "LocalBusiness",
        "@id": "https://kizercode.com/#business",
        "name": "Kizercode",
        "description": description,
        "url": "https://kizercode.com",
        "logo": "https://kizercode.com/og-image.png",
        "telephone": "+50498622160",
        "address": {
          "@type": "PostalAddress",
          "addressCountry": "HN",
          "addressLocality": "El Progreso",
          "addressRegion": "Yoro"
        },
        "contactPoint": {
          "@type": "ContactPoint",
          "contactType": "sales",
          "telephone": "+50498622160",
          "email": "hello@kizercode.com",
          "availableLanguage": ["English", "Spanish"]
        },
        "sameAs": [
          "https://www.linkedin.com/company/kizercode",
          "https://github.com/kizercode"
        ]
      },
      {
        "@type": "WebSite",
        "@id": "https://kizercode.com/#website",
        "url": "https://kizercode.com",
        "name": "Kizercode",
        "publisher": { "@id": "https://kizercode.com/#business" }
      }
    ]
  })} />

  <!-- Theme init — runs before paint to prevent flash -->
  <script is:inline>
    (function() {
      const saved = localStorage.getItem('kz-theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const theme = saved || (prefersDark ? 'dark' : 'light');
      document.documentElement.setAttribute('data-theme', theme);

      const lang = localStorage.getItem('kz-lang') || 'en';
      document.documentElement.setAttribute('lang', lang);
    })();
  </script>
</head>
<body>
  <slot />
  <script>
    // Defer GSAP to after first paint — reduces forced reflows and LCP render delay
    async function bootAnimations() {
      const { initGSAP, animateHero, animateSections, initMagneticButtons, initNavScroll } =
        await import('@/lib/animations/gsap');

      initGSAP();
      // Hero animates immediately (above the fold)
      animateHero();
      // Defer below-the-fold animations to idle time
      if ('requestIdleCallback' in window) {
        requestIdleCallback(() => {
          animateSections();
          initMagneticButtons();
          initNavScroll();
        });
      } else {
        setTimeout(() => {
          animateSections();
          initMagneticButtons();
          initNavScroll();
        }, 100);
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', bootAnimations);
    } else {
      // DOM already ready — schedule on next frame to avoid blocking paint
      requestAnimationFrame(bootAnimations);
    }
  </script>
</body>
</html>
