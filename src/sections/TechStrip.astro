---
const techs = [
  { label: 'React', icon: 'react' },
  { label: 'Next.js', icon: 'next' },
  { label: 'Flutter', icon: 'flutter' },
  { label: 'Node.js', icon: 'node' },
  { label: 'Python', icon: 'python' },
  { label: 'AWS', icon: 'aws' },
  { label: 'Docker', icon: 'docker' },
  { label: 'PostgreSQL', icon: 'postgres' },
  { label: 'MongoDB', icon: 'mongo' },
  { label: 'Figma', icon: 'figma' },
  { label: 'AI / LLMs', icon: 'ai' },
  { label: 'Stripe', icon: 'stripe' },
];
const doubled = [...techs, ...techs];
---

<div class="py-8 border-y border-border-soft bg-bg-2 overflow-hidden">
  <p class="text-center font-mono text-[11px] tracking-[3px] text-muted-2 uppercase mb-6">Trusted Technologies</p>
  <div class="relative overflow-hidden">
    <!-- Fade masks -->
    <div
      class="absolute left-0 top-0 bottom-0 w-24 z-10 pointer-events-none"
      style="background: linear-gradient(90deg, var(--color-bg-2), transparent);"
    ></div>
    <div
      class="absolute right-0 top-0 bottom-0 w-24 z-10 pointer-events-none"
      style="background: linear-gradient(-90deg, var(--color-bg-2), transparent);"
    ></div>

    <div class="flex gap-12 animate-scroll-left hover:[animation-play-state:paused] w-max">
      {doubled.map(({ label, icon }) => (
        <div class="flex items-center gap-2.5 text-muted font-semibold text-sm whitespace-nowrap cursor-pointer hover:text-brand-cyan transition-colors duration-200 group">
          <!-- Inline tech icon SVG -->
          {icon === 'react' && (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="opacity-60 group-hover:opacity-100 transition-opacity duration-200" style="color: #61dafb;">
              <circle cx="12" cy="12" r="2.2" fill="currentColor"/>
              <ellipse cx="12" cy="12" rx="10" ry="4" stroke="currentColor" stroke-width="1.5" fill="none"/>
              <ellipse cx="12" cy="12" rx="10" ry="4" stroke="currentColor" stroke-width="1.5" fill="none" transform="rotate(60 12 12)"/>
              <ellipse cx="12" cy="12" rx="10" ry="4" stroke="currentColor" stroke-width="1.5" fill="none" transform="rotate(120 12 12)"/>
            </svg>
          )}
          {icon === 'next' && (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="opacity-60 group-hover:opacity-100 transition-opacity duration-200">
              <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5" fill="none"/>
              <path d="M8 16V8l8 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M14 8h2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          )}
          {icon === 'flutter' && (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="opacity-60 group-hover:opacity-100 transition-opacity duration-200" style="color: #54c5f8;">
              <path d="M13 2L3 13l4 4 10-10z" fill="currentColor" opacity="0.7"/>
              <path d="M13 11l-3.5 3.5L13 18l7-7z" fill="currentColor"/>
            </svg>
          )}
          {icon === 'node' && (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="opacity-60 group-hover:opacity-100 transition-opacity duration-200" style="color: #68a063;">
              <path d="M12 2L3 7v10l9 5 9-5V7z" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linejoin="round"/>
              <path d="M12 2v20M3 7l9 5 9-5" stroke="currentColor" stroke-width="1.5" opacity="0.5"/>
            </svg>
          )}
          {icon === 'python' && (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="opacity-60 group-hover:opacity-100 transition-opacity duration-200" style="color: #3776ab;">
              <path d="M12 2C9 2 7 3.5 7 5v3h5v1H5C3 9 2 10.5 2 13s1 4 3 4h2v-3c0-1.5 1.5-3 5-3s5 1.5 5 3v3h2c2 0 3-1.5 3-4s-1-4-3-4h-7V8h5V5c0-1.5-2-3-5-3z" stroke="currentColor" stroke-width="1.2" fill="none"/>
              <circle cx="9.5" cy="5.5" r="1" fill="currentColor"/>
              <circle cx="14.5" cy="18.5" r="1" fill="currentColor"/>
            </svg>
          )}
          {icon === 'aws' && (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="opacity-60 group-hover:opacity-100 transition-opacity duration-200" style="color: #ff9900;">
              <path d="M6.5 14C4.5 14 3 12.5 3 10.5S4.5 7 6.5 7c0-2.2 1.8-4 4-4 1.5 0 2.8.8 3.5 2C15.5 5.5 17 7 17 9c1.7.3 3 1.8 3 3.5C20 14.4 18.4 16 16.5 16" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/>
              <path d="M8 18l2 2 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.7"/>
            </svg>
          )}
          {icon === 'docker' && (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="opacity-60 group-hover:opacity-100 transition-opacity duration-200" style="color: #2496ed;">
              <rect x="2" y="10" width="4" height="3" rx="0.5" stroke="currentColor" stroke-width="1.3" fill="none"/>
              <rect x="7" y="10" width="4" height="3" rx="0.5" stroke="currentColor" stroke-width="1.3" fill="none"/>
              <rect x="12" y="10" width="4" height="3" rx="0.5" stroke="currentColor" stroke-width="1.3" fill="none"/>
              <rect x="7" y="6" width="4" height="3" rx="0.5" stroke="currentColor" stroke-width="1.3" fill="none"/>
              <rect x="12" y="6" width="4" height="3" rx="0.5" stroke="currentColor" stroke-width="1.3" fill="none"/>
              <path d="M2 13.5C4 16 7 17 10 17c5 0 9-3 10-7" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" fill="none"/>
            </svg>
          )}
          {icon === 'postgres' && (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="opacity-60 group-hover:opacity-100 transition-opacity duration-200" style="color: #336791;">
              <ellipse cx="12" cy="7" rx="7" ry="4" stroke="currentColor" stroke-width="1.5" fill="none"/>
              <path d="M5 7v10c0 2.2 3.1 4 7 4s7-1.8 7-4V7" stroke="currentColor" stroke-width="1.5" fill="none"/>
              <path d="M5 12c0 2.2 3.1 4 7 4s7-1.8 7-4" stroke="currentColor" stroke-width="1.5" opacity="0.5"/>
            </svg>
          )}
          {icon === 'mongo' && (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="opacity-60 group-hover:opacity-100 transition-opacity duration-200" style="color: #4db33d;">
              <path d="M12 2C9 2 7 5 7 9c0 4 3 7 5 10 2-3 5-6 5-10 0-4-2-7-5-7z" stroke="currentColor" stroke-width="1.5" fill="none"/>
              <path d="M12 12v8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          )}
          {icon === 'figma' && (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="opacity-60 group-hover:opacity-100 transition-opacity duration-200" style="color: #f24e1e;">
              <rect x="5" y="2" width="6" height="6" rx="3" stroke="currentColor" stroke-width="1.5" fill="none"/>
              <rect x="13" y="2" width="6" height="6" rx="3" stroke="currentColor" stroke-width="1.5" fill="none" style="color: #a259ff;"/>
              <rect x="5" y="9" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.5" fill="none" style="color: #f24e1e;"/>
              <circle cx="16" cy="12" r="3" stroke="#1abcfe" stroke-width="1.5" fill="none"/>
              <rect x="5" y="16" width="6" height="6" rx="3" stroke="#0acf83" stroke-width="1.5" fill="none"/>
            </svg>
          )}
          {icon === 'ai' && (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="opacity-60 group-hover:opacity-100 transition-opacity duration-200" style="color: #00ff9d;">
              <rect x="3" y="8" width="18" height="10" rx="3" stroke="currentColor" stroke-width="1.5" fill="none"/>
              <circle cx="8.5" cy="13" r="1.5" fill="currentColor"/>
              <circle cx="15.5" cy="13" r="1.5" fill="currentColor"/>
              <path d="M8 8V5M12 8V4M16 8V5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          )}
          {icon === 'stripe' && (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="opacity-60 group-hover:opacity-100 transition-opacity duration-200" style="color: #635bff;">
              <rect x="2" y="4" width="20" height="16" rx="3" stroke="currentColor" stroke-width="1.5" fill="none"/>
              <path d="M2 9h20" stroke="currentColor" stroke-width="1.5"/>
              <path d="M6 14h4M14 14h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          )}
          {label}
        </div>
      ))}
    </div>
  </div>
</div>
