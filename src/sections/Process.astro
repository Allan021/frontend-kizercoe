---
const steps = [
  {
    number: '01',
    title: 'Discovery Call',
    description: 'We learn about your business, current pain points, and digital goals. No templates — just a real conversation about what matters to you.',
    duration: '1–2 days',
    color: '#00c8ff',
    icon: 'phone',
  },
  {
    number: '02',
    title: 'Proposal & Scope',
    description: 'You receive a detailed technical proposal: architecture, timelines, milestones, and transparent pricing. No hidden costs.',
    duration: '3–5 days',
    color: '#00ff9d',
    icon: 'doc',
  },
  {
    number: '03',
    title: 'Design & UX',
    description: 'Our designers craft wireframes and high-fidelity prototypes in Figma. You review and approve before a single line of code is written.',
    duration: '1–3 weeks',
    color: '#ff6b35',
    icon: 'design',
  },
  {
    number: '04',
    title: 'Development',
    description: 'Agile sprints with weekly demos. Your team gets real-time visibility into progress via a shared project board and Slack channel.',
    duration: '4–16 weeks',
    color: '#c8a0ff',
    icon: 'code',
  },
  {
    number: '05',
    title: 'Testing & QA',
    description: 'Comprehensive automated and manual testing. Load testing, security audits, cross-device checks — nothing ships without passing QA.',
    duration: '1–2 weeks',
    color: '#00ff9d',
    icon: 'check',
  },
  {
    number: '06',
    title: 'Launch + Support',
    description: 'Smooth deployment with zero-downtime strategy. After launch, we provide ongoing monitoring, updates, and feature enhancements.',
    duration: 'Ongoing',
    color: '#00c8ff',
    icon: 'rocket',
  },
];
---

<section id="process" class="py-28 px-6 md:px-[60px] bg-bg-2">
  <div class="max-w-[1200px] mx-auto">
    <!-- Header -->
    <div class="text-center mb-16" data-gsap="fade-up">
      <span class="section-tag center mb-5">
        <span class="en">How We Work</span><span class="es">Cómo Trabajamos</span>
      </span>
      <h2 class="text-4xl md:text-5xl font-black tracking-tight mt-4 mb-5">
        <span class="en">From idea to launch —<br /><span class="gradient-text">a proven process.</span></span>
        <span class="es">De la idea al lanzamiento —<br /><span class="gradient-text">un proceso probado.</span></span>
      </h2>
      <p class="text-muted text-lg max-w-[520px] mx-auto leading-relaxed">
        <span class="en">Six structured phases that eliminate surprises, keep you informed, and deliver results on time.</span>
        <span class="es">Seis fases estructuradas que eliminan sorpresas, te mantienen informado y entregan resultados a tiempo.</span>
      </p>
    </div>

    <!-- Steps grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 relative">
      {steps.map((step, index) => (
        <div
          class="process-step-item group rounded-2xl p-7 border border-border-soft hover:border-brand-cyan/25 transition-all duration-300 relative overflow-hidden"
          style="background: var(--color-card);"
        >
          <!-- Top accent line -->
          <div
            class="absolute top-0 left-7 right-7 h-[2px] opacity-0 group-hover:opacity-100 transition-opacity duration-300 rounded-full"
            style={`background: linear-gradient(90deg, transparent, ${step.color}, transparent);`}
          ></div>

          <!-- Step number + icon row -->
          <div class="flex items-center justify-between mb-5">
            <span
              aria-hidden="true"
              class="font-mono text-[42px] font-black leading-none select-none"
              style={`color: ${step.color}60;`}
            >
              {step.number}
            </span>
            <div
              class="w-11 h-11 rounded-xl flex items-center justify-center"
              style={`background: ${step.color}18; border: 1px solid ${step.color}30;`}
            >
              {step.icon === 'phone' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" style={`color: ${step.color};`}>
                  <path d="M5 4h4l2 5-2.5 1.5a11 11 0 005 5L15 13l5 2v4a2 2 0 01-2 2C7 21 3 10 3 6a2 2 0 012-2z" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linejoin="round"/>
                </svg>
              )}
              {step.icon === 'doc' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" style={`color: ${step.color};`}>
                  <path d="M14 3H6a2 2 0 00-2 2v14a2 2 0 002 2h12a2 2 0 002-2V8l-6-5z" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linejoin="round"/>
                  <path d="M14 3v5h5M8 12h8M8 16h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              )}
              {step.icon === 'design' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" style={`color: ${step.color};`}>
                  <rect x="3" y="3" width="8" height="8" rx="1.5" stroke="currentColor" stroke-width="1.8" fill="none"/>
                  <rect x="13" y="3" width="8" height="8" rx="1.5" stroke="currentColor" stroke-width="1.8" fill="none"/>
                  <rect x="3" y="13" width="8" height="8" rx="1.5" stroke="currentColor" stroke-width="1.8" fill="none"/>
                  <circle cx="17" cy="17" r="4" stroke="currentColor" stroke-width="1.8" fill="none"/>
                  <path d="M17 15v2l1 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              )}
              {step.icon === 'code' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" style={`color: ${step.color};`}>
                  <path d="M8 9l-4 3 4 3M16 9l4 3-4 3M14 5l-4 14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              )}
              {step.icon === 'check' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" style={`color: ${step.color};`}>
                  <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8" fill="none"/>
                </svg>
              )}
              {step.icon === 'rocket' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" style={`color: ${step.color};`}>
                  <path d="M4.5 16.5c-1.5 1.5-2 5-2 5s3.5-.5 5-2l4-4c2 .5 5 0 7.5-2.5C22 10.5 22 5 22 5s-5.5 0-8 2.5c-2.5 2.5-3 5.5-2.5 7.5l-4.5 1.5z" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linejoin="round"/>
                  <circle cx="15" cy="9" r="1.5" fill="currentColor"/>
                </svg>
              )}
            </div>
          </div>

          <!-- Content -->
          <h3 class="text-lg font-bold text-primary mb-3 group-hover:text-brand-cyan transition-colors duration-200">
            {step.title}
          </h3>
          <p class="text-muted text-sm leading-relaxed mb-4">{step.description}</p>

          <!-- Duration badge -->
          <div
            class="process-dur-badge inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[11px] font-mono font-semibold"
            style={`background: ${step.color}10; color: ${step.color}; border: 1px solid ${step.color}20;`}
          >
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
              <circle cx="5" cy="5" r="4" stroke="currentColor" stroke-width="1.2"/>
              <path d="M5 2.5V5l1.5 1.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
            </svg>
            {step.duration}
          </div>

          <!-- Arrow connector (not on last in each row) -->
          {index % 3 !== 2 && index < steps.length - 1 && (
            <div class="hidden lg:block absolute -right-3 top-1/2 -translate-y-1/2 z-10">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                <path d="M5 12h14M15 8l4 4-4 4" stroke="rgba(0,200,255,0.3)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="mt-14 text-center" data-gsap="fade-up">
      <p class="text-muted mb-5">
        <span class="en">Ready to start the process?</span><span class="es">¿Listo para comenzar?</span>
      </p>
      <a
        href="#contact"
        data-magnetic
        class="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-bold text-[15px] text-bg bg-gradient-to-br from-brand-cyan to-brand-electric shadow-btn hover:shadow-btn-hover hover:-translate-y-0.5 transition-all duration-200 cursor-pointer"
      >
        <span class="en">Book a free discovery call</span><span class="es">Agenda una llamada gratuita</span>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</section>
